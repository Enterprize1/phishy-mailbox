    "eml-parser": "^2.1.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "isomorphic-dompurify": "^3.17.0",
    "lodash.debounce": "^4.0.8",
    "material-ui-confirm": "^4.0.0",
    "next": "16.2.9",
